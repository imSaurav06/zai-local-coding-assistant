# ============================================================
# Dependencies (never commit node_modules)
# ============================================================
node_modules/
frontend/node_modules/
backend/node_modules/

# ============================================================
# Production builds (generated — do not commit)
# ============================================================
frontend/dist/
backend/dist/

# ============================================================
# Local Environment files (secrets — never commit)
# ============================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env

# ============================================================
# Live Preview sandbox workspaces (runtime temp — never commit)
# ============================================================
temp_previews/
backend/temp_previews/

# ============================================================
# Temporary files, caches, artifacts
# ============================================================
.DS_Store
Thumbs.db
backend/scratch/
*.zip
*.log
